<?xml version="1.0" encoding="utf-8"?>
<!--
    TrueChrome — AndroidManifest.xml
    =================================
    Declares permissions, hardware requirements, and the single-Activity architecture.
    
    KEY DECISIONS:
    - Single Activity (MainActivity) hosts all Compose screens
    - Camera permission is required (not optional) — app is useless without it
    - screenOrientation locked to portrait to prevent camera session teardown on rotation
    - configChanges handles common config changes without Activity recreation
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Camera access — the core permission for this app -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Vibration for haptic shutter feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        Storage permissions for saving JPEG to MediaStore.
        On API 29+ (scoped storage), WRITE_EXTERNAL_STORAGE is automatically ignored,
        but we declare it for API 28 backward compatibility.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Declare that this app REQUIRES a camera to function -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="true" />

    <!-- OpenGL ES 3.0 required for 3D LUT textures and multi-pass shader pipeline -->
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />

    <application
        android:name=".TrueChromeApplication"
        android:allowBackup="false"
        android:label="TrueChrome"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrueChrome">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
